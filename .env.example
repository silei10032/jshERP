# 复制为 .env 后填入真实值；.env 已 gitignore 不会提交
#
# 本地开发：仅需填 DB_PASSWORD 和 REDIS_PASSWORD（其余用默认）
# 生产部署：建议显式覆盖 REDIS_DB / LOG_LEVEL_APP / UPLOAD_DIR / EXPORT_DIR / JAVA_OPTS

# === 必填 ===
DB_PASSWORD=root12345
REDIS_PASSWORD=root12345

# === 可选（有默认值，按需覆盖） ===

# --- 数据库 ---
# DB_NAME=mogoo_erp
# DB_PORT=3306
# DB_USERNAME=root

# --- Redis ---
# REDIS_PORT=6379
# Redis db 编号；prod 多项目共享 Redis 时用此区分，mogooErp 建议 1
# REDIS_DB=1

# --- 端口（同时跑多套环境时改）---
# APP_PORT=8090
# FRONTEND_PORT=8091

# --- 日志级别 ---
# 本地用 DEBUG 看 SQL，prod 用 INFO 减少噪音
# LOG_LEVEL_APP=INFO

# --- 文件持久化路径（host 绝对路径表示 bind mount，否则 named volume）---
# UPLOAD_DIR=/data/mogoo-erp/upload
# EXPORT_DIR=/data/mogoo-erp/export

# --- JVM 堆大小 ---
# JAVA_OPTS=-Xms512m -Xmx1024m -Dfile.encoding=UTF-8 -Duser.timezone=Asia/Shanghai
